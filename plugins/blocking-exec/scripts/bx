#!/usr/bin/env python3
"""Replay a command result captured by the Blocking Exec hook."""

from __future__ import annotations

import sys
from pathlib import Path


LOG_DIR = Path("/tmp/bx")


def usage() -> int:
    print(
        "usage: bx <status> <file-id> -- <command>",
        file=sys.stderr,
    )
    return 2


def read_status(value: str) -> int:
    try:
        return int(value)
    except ValueError:
        return 1


def main() -> int:
    if len(sys.argv) < 4 or sys.argv[3] != "--":
        return usage()

    _, status_arg, file_id, _separator, *_command = sys.argv
    if Path(file_id).name != file_id or file_id in {"", ".", ".."}:
        print(f"bx: invalid file id: {file_id}", file=sys.stderr)
        return 2

    log_path = LOG_DIR / file_id
    try:
        with log_path.open("rb") as log:
            sys.stdout.buffer.write(log.read())
    except OSError as exc:
        print(
            f"bx: unable to read captured output: {exc}",
            file=sys.stderr,
        )
        return 127

    return read_status(status_arg)


if __name__ == "__main__":
    raise SystemExit(main())
